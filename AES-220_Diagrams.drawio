        <mxCell id="rleg2" value="NSX Overlay — GENEVE encapsulated overlay routing" style="text;html=1;strokeColor=#2E75B6;fillColor=#dbeafe;fontSize=9;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="955" width="260" height="20" as="geometry"/></mxCell>
        <mxCell id="rleg3" value="VLAN Static — direct physical (no NSX dependency)" style="text;html=1;strokeColor=#375623;fillColor=#e2efda;fontSize=9;fontStyle=1;rounded=1;" vertex="1" parent="1">
