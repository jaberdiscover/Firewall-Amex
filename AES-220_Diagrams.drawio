        <mxCell id="ra2" value="BGP" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#7030A0;strokeWidth=2;endArrow=block;startArrow=block;" edge="1" source="r_spine" target="r_tor" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra3" value="BGP Peer" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#7030A0;strokeWidth=2;endArrow=block;startArrow=block;" edge="1" source="r_tor" target="r_edge" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra4" value="N-S Routing" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#7030A0;strokeWidth=2;endArrow=block;startArrow=block;" edge="1" source="r_edge" target="r_t0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra5" value="E-W Distributed" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#7030A0;strokeWidth=2;endArrow=block;startArrow=block;" edge="1" source="r_t0" target="r_dtgw" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra6" value="NSX Overlay" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#2E75B6;strokeWidth=2;" edge="1" source="r_dtgw" target="r_fleet" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra7" value="VLAN Direct" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#1F3864;strokeWidth=2;" edge="1" source="r_tor" target="r_mgmt" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra8" value="VPC Segments" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#375623;strokeWidth=2;" edge="1" source="r_dtgw" target="r_wld" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Warning box -->
        <mxCell id="warn" value="⚠️  FLEET SEGMENT DEPENDENCY WARNING&#xa;Fleet VMs (VCFA, VCFO, VIDB) route through NSX T0/T1/DTGW stack. If NSX Edge goes down during maintenance, Fleet overlay loses routing.&#xa;VCF Automation and Identity Broker become unreachable. SDDC Manager SSO authentication may fail.&#xa;ACTION: Always coordinate Edge maintenance windows with VCF Ops team. Never patch all Edge nodes simultaneously." style="text;html=1;strokeColor=#FF9900;fillColor=#FFF2CC;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="810" width="920" height="70" as="geometry"/>
        </mxCell>

        <!-- TEP info box -->
        <mxCell id="tep_info" value="NSX TEP VLANS:  Host TEP (to be confirmed per site)  |  Edge TEP: VLAN 2603  |  Remote TEP (cross-AZ): VLAN 2605  |  MTU must be 1600+ on all TEP paths for GENEVE encapsulation" style="text;html=1;strokeColor=#7030A0;fillColor=#f3e5f5;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
