        <!-- Stack arrows -->
        <mxCell id="ra1" value="BGP" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontStyle=1;strokeColor=#7030A0;strokeWidth=2;endArrow=block;startArrow=block;" edge="1" source="r_ext" target="r_spine" parent="1">
