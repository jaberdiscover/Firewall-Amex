        <mxCell id="r_edge" value="NSX Edge Nodes  |  Edge TEP VLAN 2603  |  BGP Peers to ToR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7030A0;strokeColor=#5a1a8a;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="380" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r_t0" value="T0 Gateway (per AZ)  |  N-S Routing  |  BGP to Edge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7030A0;strokeColor=#5a1a8a;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="480" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r_dtgw" value="T1 / DTGW — Distributed Tier Gateway  |  E-W on host (no Edge hairpin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7030A0;strokeColor=#5a1a8a;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="580" width="340" height="50" as="geometry"/>
        </mxCell>

        <!-- Three branches at bottom -->
        <mxCell id="r_fleet" value="Fleet Overlay Segment&#xa;VCF Ops · VCFA · VOL · VON · VIDB&#xa;Route: NSX Overlay via T0/T1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E75B6;strokeColor=#1F3864;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r_mgmt" value="VLAN 2600 — Direct Physical&#xa;vCenter · NSX Mgr · SDDC Mgr&#xa;No NSX overlay dependency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1F3864;strokeColor=#0d3268;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="700" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r_wld" value="WLD VPC Segments&#xa;Workload VMs · ESXi Hosts&#xa;Route: DTGW → VPC GW → Segments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#375623;strokeColor=#2a4019;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="700" width="200" height="70" as="geometry"/>
