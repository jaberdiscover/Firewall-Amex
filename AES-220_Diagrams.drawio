        <mxCell id="rleg1" value="BGP — dynamic route advertisement (Edge↔ToR↔Spine)" style="text;html=1;strokeColor=#7030A0;fillColor=#f3e5f5;fontSize=9;fontStyle=1;rounded=1;" vertex="1" parent="1">
